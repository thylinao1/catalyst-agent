# Copy this file to ".env" and fill in your key.
# News comes from public RSS feeds, so the ONLY credential needed is Gemini.

# Google Gemini - free tier key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# --- Optional overrides (sensible defaults are used if omitted) ---
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001
DB_PATH=catalyst.db

# Comma-separated RSS feed URLs. Leave unset to use the built-in defaults
# (CoinDesk, Cointelegraph, Decrypt).
# RSS_FEEDS=https://www.coindesk.com/arc/outboundfeeds/rss/,https://cointelegraph.com/rss
